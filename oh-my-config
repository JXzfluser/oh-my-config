def cmd_list(args):
    project = args.project
    if not project:
        print('错误: 需要指定项目 (-p)', file=sys.stderr)
        return 1
    
    r = requests.get(f'{API}/api/configs/{project}').json()
    for c in r:
        print(f'{c["type"]}/{c["name"]}')

def cmd_get(args):
    project, typ, name = args.project, args.type, args.name
    if not all([project, typ, name]):
        print('错误: 需要 -p -t -n', file=sys.stderr)
        return 1
    
    r = requests.get(f'{API}/api/config/{project}/{typ}/{name}').json()
    print(r.get('content', ''))
    return 0

def cmd_set(args):
    project, typ, name = args.project, args.type, args.name
    if not all([project, typ, name]):
        print('错误: 需要 -p -t -n', file=sys.stderr)
        return 1
    
    content = args.content or sys.stdin.read()
    
    r = requests.post(f'{API}/api/config', json={
        'project': project,
        'type': typ,
        'name': name,
        'content': content
    })
    if r.status_code == 200:
        print(f'✓ 已保存 {typ}/{name}')
        return 0
    else:
        print(f'错误: {r.text}', file=sys.stderr)
        return 1

def cmd_sync(args):
    project = args.project
    if not project:
        print('错误: 需要 -p', file=sys.stderr)
        return 1
    
    target = args.target or f'~/projects/{project}'
    r = requests.post(f'{API}/api/sync', json={'project': project, 'target': target})
    if r.status_code == 200:
        print(f'✓ 已同步到 {target}')
        return 0
    else:
        print(f'错误: {r.text}', file=sys.stderr)
        return 1

def cmd_ai(args):
    import datetime
    project = args.project
    prompt = args.prompt
    typ = args.type or 'wiki'
    name = args.name or 'ai-generated'
    
    if not project:
        print('错误: 需要 -p', file=sys.stderr)
        return 1
    
    if not prompt:
        print('错误: 需要 --prompt', file=sys.stderr)
        return 1
    
    content = f'''# AI 生成的内容

## 请求

{prompt}

## 生成时间

{datetime.datetime.now().isoformat()}

## 说明

请编辑此内容以匹配你的需求。
'''
    
    r = requests.post(f'{API}/api/config', json={
        'project': project,
        'type': typ,
        'name': name,
        'content': content
    })
    
    if r.status_code == 200:
        print(f'✓ 已生成 {typ}/{name}')
        return 0
    else:
        print(f'错误: {r.text}', file=sys.stderr)
        return 1

def main():
    parser = argparse.ArgumentParser(prog='oh-my-config')
    sub = parser.add_subparsers()
    
    p_projects = sub.add_parser('projects', help='列出项目')
    p_projects.set_defaults(func=cmd_projects)
    
    p_init = sub.add_parser('init', help='初始化项目')
    p_init.add_argument('name', nargs='?')
    p_init.add_argument('-d', '--description')
    p_init.set_defaults(func=cmd_init)
    
    p_list = sub.add_parser('list', help='列出配置')
    p_list.add_argument('-p', '--project', required=True)
    p_list.set_defaults(func=cmd_list)
    
    p_get = sub.add_parser('get', help='获取配置')
    p_get.add_argument('-p', '--project', required=True)
    p_get.add_argument('-t', '--type', required=True)
    p_get.add_argument('-n', '--name', required=True)
    p_get.set_defaults(func=cmd_get)
    
    p_set = sub.add_parser('set', help='设置配置')
    p_set.add_argument('-p', '--project', required=True)
    p_set.add_argument('-t', '--type', required=True)
    p_set.add_argument('-n', '--name', required=True)
    p_set.add_argument('-c', '--content', default='')
    p_set.set_defaults(func=cmd_set)
    
    p_sync = sub.add_parser('sync', help='同步到目录')
    p_sync.add_argument('-p', '--project', required=True)
    p_sync.add_argument('-t', '--target')
    p_sync.set_defaults(func=cmd_sync)
    
    p_ai = sub.add_parser('ai', help='AI 生成配置')
    p_ai.add_argument('-p', '--project', required=True)
    p_ai.add_argument('--prompt', required=True)
    p_ai.add_argument('-t', '--type', default='wiki')
    p_ai.add_argument('-n', '--name')
    p_ai.set_defaults(func=cmd_ai)
    
    args = parser.parse_args()
    if hasattr(args, 'func'):
        return args.func(args)
    parser.print_help()
    return 0

if __name__ == '__main__':
    sys.exit(main())