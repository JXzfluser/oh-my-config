#!/bin/bash
# oh-my-config CLI (using curl)

API="${OMC_API:-http://localhost:8848}"

cmd_projects() {
  curl -s "$API/api/projects" | python3 -m json.tool 2>/dev/null || curl -s "$API/api/projects"
}

cmd_init() {
  local name="$1"
  local scan_path="$2"
  
  # Determine project name and scan path
  if [ -n "$scan_path" ]; then
    # omc init myproject /path/to/project
    local project_name="$name"
    local project_path="$scan_path"
  elif [ -n "$name" ]; then
    if [ -d "$name" ]; then
      # omc init /path/to/project (is a directory)
      local project_path="$name"
      local project_name=$(basename "$name")
    else
      # omc init myproject (use current dir)
      local project_name="$name"
      local project_path="."
    fi
  else
    # omc init (current directory)
    local project_name=$(basename "$(pwd)")
    local project_path="."
  fi
  
  echo "Initializing: $project_name"
  echo "Path: $project_path"
  echo ""
  
  # Check if path exists
  if [ ! -d "$project_path" ]; then
    echo "✗ Directory not found: $project_path"
    return 1
  fi
  
  local result=$(curl -s -X POST "$API/api/scan-import" \
    -H "Content-Type: application/json" \
    -d "{\"name\":\"$project_name\",\"path\":\"$project_path\"}")
    
  local success=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('success', False))" 2>/dev/null)
  
  if [ "$success" = "True" ]; then
    local configs=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(', '.join(d.get('configs', {}).get('config', [])))" 2>/dev/null)
    local modules=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); mods=d.get('project_info',{}).get('modules',[]); print(', '.join(set(mods)))" 2>/dev/null)
    local files=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('files', 0))" 2>/dev/null)
    
    echo "✓ Project '$project_name' created"
    echo ""
    echo "📋 项目信息:"
    echo "   路径: $project_path"
    echo "   配置: $configs"
    echo "   模块: $modules"
    echo "   文件: $files 个"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "🤖 AI 代码分析报告"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "项目路径: $project_path"
    echo ""
    echo "【模块结构】"
    echo "$modules" | tr ',' '\n' | while read m; do echo "  - $m"; done
    echo ""
    echo "【配置文件】"
    echo "  $configs"
    echo ""
    echo "【关键文件】"
    find "$project_path" -maxdepth 3 -name "*.java" -type f 2>/dev/null | head -30 | while read f; do echo "  $f"; done
    echo ""
    echo "【pom.xml 依赖】"
    grep -A2 "<dependency>" "$project_path/pom.xml" 2>/dev/null | grep -E "(artifactId|groupId)" | head -30 | sed 's/^/  /'
    echo ""
    echo "【README 内容】"
    if [ -f "$project_path/README.md" ]; then head -20 "$project_path/README.md" | sed 's/^/  /'; fi
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "请基于以上代码信息，为 '$project_name' 项目生成 AGENTS.md 规范文件。"
    echo ""
    echo "保存命令："
    echo "omc set $project_name spec AGENTS 'AGENTS.md内容'"
  else
    echo "✗ Failed to create project"
    echo "$result"
  fi
}

cmd_list() {
  local project="$1"
  curl -s "$API/api/configs/$project" | python3 -c "import sys,json; [print(f'{c[\"type\"]}/{c[\"name\"]}') for c in json.load(sys.stdin)]"
}

cmd_get() {
  local project="$1" type="$2" name="$3"
  curl -s "$API/api/config/$project/$type/$name"
}

cmd_set() {
  local project="$1" type="$2" name="$3"
  local content="$4"
  curl -s -X POST "$API/api/config" \
    -H "Content-Type: application/json" \
    -d "{\"project\":\"$project\",\"type\":\"$type\",\"name\":\"$name\",\"content\":\"$content\"}"
}

cmd_debug() {
  local project="$1" config="$2"
  if [ -n "$config" ]; then
    curl -s "$API/api/config/$project/$config" | python3 -m json.tool
  else
    curl -s "$API/api/configs/$project" | python3 -m json.tool
  fi
}

cmd_sync() {
  local project="$1"
  curl -s -X POST "$API/api/sync/$project"
}

cmd_env() {
  local project="$1"
  curl -s "$API/api/configs/$project" | python3 -c "
import sys,json
for c in json.load(sys.stdin):
  print(f'{project.upper()}_{c[\"type\"].upper()}_{c[\"name\"].upper()}={c.get(\"content\",\"\")}')" 2>/dev/null
}

cmd_mcp() {
  local project="${1:-.}"
  local project_path
  
  if [ -d "$project" ]; then
    project_path="$project"
  else
    project_path="."
  fi
  
  # Check if .omc.json exists
  if [ -f "$project_path/.omc.json" ]; then
    echo "Starting oh-my-config MCP server for: $project_path"
    echo "Press Ctrl+C to stop"
    cd "$project_path" && uv run --with mcp --with mysql-connector-python --with redis python3 /Users/zfl/projects/oh-my-config/mcp-server/server.py "$project_path"
  else
    echo "No .omc.json found in $project_path"
    echo "Run 'omc init $project_path' first"
    return 1
  fi
}

cmd_config() {
  local project="${1:-.}"
  local project_path
  
  if [ -d "$project" ]; then
    project_path="$project"
  else
    project_path="."
  fi
  
  # Generate .omc.json from scan results
  local config_file="$project_path/.omc.json"
  if [ -f "$config_file" ]; then
    cat "$config_file"
  else
    echo "No .omc.json found in $project_path"
    return 1
  fi
}

# Main
case "$1" in
  projects) cmd_projects ;;
  init) shift; cmd_init "$@" ;;
  list) shift; cmd_list "$@" ;;
  get) shift; cmd_get "$@" ;;
  set) shift; cmd_set "$@" ;;
  debug) shift; cmd_debug "$@" ;;
  sync) shift; cmd_sync "$@" ;;
  env) shift; cmd_env "$@" ;;
  mcp) shift; cmd_mcp "$@" ;;
  config) shift; cmd_config "$@" ;;
  *) 
    echo "omc - 项目配置管理工具"
    echo ""
    echo "用法:"
    echo "  omc projects              # 列出所有项目"
    echo "  omc init [name] [path]   # 初始化项目(无参数=当前目录)"
    echo "  omc list <project>        # 列出项目配置"
    echo "  omc get <project> <type> <name>  # 获取配置"
    echo "  omc debug <project> [config]    # 调试查看配置"
    echo "  omc env <project>          # 生成环境变量"
    echo "  omc set <project> <type> <name> <content>  # 设置配置"
    echo "  omc mcp [project]       # 启动 MCP Server"
    echo "  omc config [project]    # 查看项目配置"
    echo ""
    echo "例子:"
    echo "  omc init myproject /path/to/project"
    echo "  omc init /path/to/project"
    echo "  omc set myproject spec AGENTS 'AGENTS.md内容'"
    echo "  omc mcp .               # 启动当前项目 MCP"
    echo "  omc config .            # 查看当前项目配置"
    ;;
esac