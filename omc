#!/bin/bash
# oh-my-config CLI (using curl)

API="${OMC_API:-http://localhost:8848}"

cmd_projects() {
  curl -s "$API/api/projects" | python3 -m json.tool 2>/dev/null || curl -s "$API/api/projects"
}

cmd_init() {
  local name="$1"
  local desc="$2"
  
  curl -s -X POST "$API/api/project" \
    -H "Content-Type: application/json" \
    -d "{\"name\":\"$name\",\"description\":\"$desc\"}" >/dev/null
  
  curl -s -X POST "$API/api/config" \
    -H "Content-Type: application/json" \
    -d "{\"project\":\"$name\",\"type\":\"wiki\",\"name\":\"README\",\"content\":\"# $name\n\n$desc\n\n---\n\nGenerated by oh-my-config\"}"
  
  echo "✓ Created project $name"
}

cmd_list() {
  local project="$1"
  curl -s "$API/api/configs/$project" | python3 -c "import sys,json; [print(f'{c[\"type\"]}/{c[\"name\"]}') for c in json.load(sys.stdin)]"
}

cmd_get() {
  local project="$1" type="$2" name="$3"
  curl -s "$API/api/config/$project/$type/$name"
}

cmd_set() {
  local project="$1" type="$2" name="$3" content="$4"
  curl -s -X POST "$API/api/config" \
    -H "Content-Type: application/json" \
    -d "{\"project\":\"$project\",\"type\":\"$type\",\"name\":\"$name\",\"content\":$(echo "$content" | python3 -m json.tool | head -c -1 | tail -c +2)}"
}

cmd_sync() {
  local project="$1" target="$2"
  curl -s -X POST "$API/api/sync" \
    -H "Content-Type: application/json" \
    -d "{\"project\":\"$project\",\"target\":\"$target\"}"
}

cmd_ai() {
  local project="$1" prompt="$2" typ="$3" name="$4"
  local content="# AI 生成\n\n## 请求\n\n$prompt\n\n---\n\nGenerated by oh-my-config"
  
  curl -s -X POST "$API/api/config" \
    -H "Content-Type: application/json" \
    -d "{\"project\":\"$project\",\"type\":\"$typ\",\"name\":\"$name\",\"content\":\"$content\"}"
  echo "✓ Generated $typ/$name"
}

case "$1" in
  projects) cmd_projects ;;
  init) cmd_init "$2" "$3" ;;
  list) cmd_list "$2" ;;
  get) cmd_get "$2" "$3" "$4" ;;
  set) cmd_set "$2" "$3" "$4" "$5" ;;
  sync) cmd_sync "$2" "$3" ;;
  ai) cmd_ai "$2" "$3" "$4" "$5" ;;
  *) echo "Usage: $0 {projects|init|list|get|set|sync|ai}" ;;
esac