#!/bin/bash
# oh-my-config CLI (using curl)

API="${OMC_API:-http://localhost:8848}"

cmd_projects() {
  curl -s "$API/api/projects" | python3 -m json.tool 2>/dev/null || curl -s "$API/api/projects"
}

cmd_init() {
  local name="$1"
  local desc="$2"
  
  if [ -z "$name" ]; then
    # Initialize current directory as omc project
    name=$(basename "$(pwd)")
    echo "Initializing current directory as omc project: $name"
    
    # Create .project-id
    echo "$name" > .project-id
    
    # Create .omc directory with skill
    mkdir -p .omc
    curl -s "$API/api/skill" > .omc/SKILL.md 2>/dev/null || echo "# $name\n\n> Initialized by oh-my-config" > .omc/SKILL.md
    
    echo "✓ Initialized $name"
    echo "  - .project-id created"
    echo "  - .omc/ directory created"
    return 0
  fi
  
  curl -s -X POST "$API/api/project" \
    -H "Content-Type: application/json" \
    -d "{\"name\":\"$name\",\"description\":\"$desc\"}" >/dev/null
  
  curl -s -X POST "$API/api/config" \
    -H "Content-Type: application/json" \
    -d "{\"project\":\"$name\",\"type\":\"wiki\",\"name\":\"README\",\"content\":\"# $name\n\n$desc\n\n---\n\nGenerated by oh-my-config\"}"
  
  echo "✓ Created project $name"
}

cmd_list() {
  local project="$1"
  curl -s "$API/api/configs/$project" | python3 -c "import sys,json; [print(f'{c[\"type\"]}/{c[\"name\"]}') for c in json.load(sys.stdin)]"
}

cmd_get() {
  local project="$1" type="$2" name="$3"
  curl -s "$API/api/config/$project/$type/$name"
}

cmd_set() {
  local project="$1" type="$2" name="$3" content="$4"
  curl -s -X POST "$API/api/config" \
    -H "Content-Type: application/json" \
    -d "{\"project\":\"$project\",\"type\":\"$type\",\"name\":\"$name\",\"content\":$(echo "$content" | python3 -m json.tool | head -c -1 | tail -c +2)}"
}

cmd_sync() {
  local project="$1" target="$2"
  curl -s -X POST "$API/api/sync" \
    -H "Content-Type: application/json" \
    -d "{\"project\":\"$project\",\"target\":\"$target\"}"
}

cmd_debug() {
  local project="$1"
  if [ -z "$project" ]; then
    echo "Usage: $0 debug <project> [config_name]"
    echo ""
    echo "示例:"
    echo "  $0 debug chuanplus-platform       # 查看所有配置"
    echo "  $0 debug chuanplus-platform MYSQL # 查看 MYSQL 配置"
    return 1
  fi
  
  local config_name="$2"
  
  if [ -z "$config_name" ]; then
    echo "=== 项目: $project 所有配置 ==="
    curl -s "$API/api/configs/$project" | python3 -c "
import sys,json
configs = json.load(sys.stdin)
for c in configs:
    mask = '******' if c.get('content') and ('password' in c['content'] or 'secret' in c['content']) else ''
    if mask:
        print(f\"{c['type']:10} {c['name']:20} (已脱敏)\")
    else:
        print(f\"{c['type']:10} {c['name']}\")
"
  else
    echo "=== $config_name 配置 ==="
    local config_json=$(curl -s "$API/api/configs/$project")
    local config_type=$(curl -s "$API/api/configs/$project" | python3 -c "
import sys,json
configs = json.load(sys.stdin)
for c in configs:
    if c['name'] == '$config_name':
        print(c['type'])
        break
")
    if [ -n "$config_type" ]; then
      curl -s "$API/api/config/$project/$config_type/$config_name" | python3 -m json.tool
    else
      echo "未找到配置: $config_name"
    fi
  fi
}

cmd_env() {
  local project="$1"
  if [ -z "$project" ]; then
    echo "Usage: $0 env <project>"
    echo ""
    echo "生成调试用的环境变量配置"
    return 1
  fi
  
  echo "# $project 环境变量"
  echo ""
  
  # 读取配置并格式化输出
  curl -s "$API/api/configs/$project" | python3 -c "
import sys, json, re

configs = json.load(sys.stdin)
for c in configs:
    name = c['name']
    conf = c.get('content', '{}')
    if isinstance(conf, str):
        try:
            conf = json.loads(conf)
        except:
            pass
    
    if name == 'MYSQL':
        print(f\"MYSQL_HOST={conf.get('host', '')}\")
        print(f\"MYSQL_PORT={conf.get('port', 3306)}\")
        print(f\"MYSQL_DB={conf.get('database', '')}\")
        print(f\"MYSQL_USER={conf.get('username', '')}\")
        print(f\"MYSQL_PASS={conf.get('password', '')}\")
    elif name == 'REDIS':
        print(f\"REDIS_HOST={conf.get('host', '')}\")
        print(f\"REDIS_PORT={conf.get('port', 6379)}\")
        print(f\"REDIS_PASS={conf.get('password', '')}\")
        print(f\"REDIS_DB={conf.get('database', 0)}\")
    elif name == 'ELASTICSEARCH':
        print(f\"ES_HOSTS={','.join(conf.get('nodes', []))}\")
        print(f\"ES_USER={conf.get('username', '')}\")
        print(f\"ES_PASS={conf.get('password', '')}\")
    elif name == 'NACOS':
        print(f\"NACOS_SERVER={conf.get('serverAddr', '')}\")
        print(f\"NACOS_NAMESPACE={conf.get('namespace', '')}\")
    elif name == 'RABBITMQ':
        print(f\"RABBITMQ_HOST={conf.get('host', '')}\")
        print(f\"RABBITMQ_PORT={conf.get('port', 5672)}\")
        print(f\"RABBITMQ_USER={conf.get('username', '')}\")
        print(f\"RABBITMQ_PASS={conf.get('password', '')}\")
        print(f\"RABBITMQ_VHOST={conf.get('vhost', '')}\")
" 2>/dev/null
}

case "$1" in
  projects) cmd_projects ;;
  init) cmd_init "$2" "$3" ;;
  list) cmd_list "$2" ;;
  get) cmd_get "$2" "$3" "$4" ;;
  set) cmd_set "$2" "$3" "$4" "$5" ;;
  sync) cmd_sync "$2" "$3" ;;
  debug) cmd_debug "$2" ;;
  env) cmd_env "$2" ;;
  *) 
    echo "omc - 项目配置管理工具"
    echo ""
    echo "用法:"
    echo "  omc projects              # 列出所有项目"
    echo "  omc init [name] [desc]   # 初始化项目(无参数=当前目录)"
    echo "  omc list <project>        # 列出项目配置"
    echo "  omc get <project> <type> <name>  # 获取配置"
    echo "  omc debug <project> [config]    # 调试查看配置"
    echo "  omc env <project>          # 生成环境变量"
    echo "  omc sync <project> <dir>   # 同步到目录"
    ;;
esac